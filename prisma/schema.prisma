generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  name          String?
  image         String?
  syncFromDate  DateTime?
  gmailSyncedAt DateTime?
  lastMessageId String?
  createdAt     DateTime            @default(now())
  emailVerified DateTime?
  accounts      Account[]
  assets        Asset[]
  categories    Category[]
  reconLogs     ReconciliationLog[]
  sessions      Session[]
  syncJobs           SyncJob[]
  transactions       Transaction[]
  merchantRules      MerchantRule[]
  statementPasswords StatementPassword[]
  parseLogs          ParseLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  gmailMsgId  String?
  fingerprint String?
  date        DateTime
  merchant    String
  amount      Float
  type        String
  currency    String   @default("INR")
  category    String
  tag         String?
  source      String   @default("gmail")
  sourceRank  Int      @default(3)
  reviewed    Boolean  @default(false)
  needsReview Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMsgId])
  @@unique([userId, fingerprint])
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  value     Float
  currency  String   @default("INR")
  asOf      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  icon      String
  color     String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailFilter {
  id         String   @id @default(cuid())
  type       String
  value      String
  sourceRank Int      @default(3)
  isActive   Boolean  @default(true)
  addedAt    DateTime @default(now())
  note       String?

  @@unique([type, value])
}

model SyncJob {
  id                    String           @id @default(cuid())
  userId                String
  status                String           @default("running")
  totalEmails           Int              @default(0)
  processedEmails       Int              @default(0)
  newTransactions       Int              @default(0)
  skippedEmails         Int              @default(0)
  encryptedBlockedCount Int              @default(0)
  isRetrigger           Boolean          @default(false)
  startedAt             DateTime         @default(now())
  completedAt           DateTime?
  scanPageToken         String?
  gmailQuery            String?
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages              SyncJobMessage[]
}

model SyncJobMessage {
  id         String  @id @default(cuid())
  syncJobId  String
  gmailMsgId String
  processed  Boolean @default(false)
  syncJob    SyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@unique([syncJobId, gmailMsgId])
  @@index([syncJobId, processed])
}

model ReconciliationLog {
  id                   String    @id @default(cuid())
  userId               String
  statementGmailMsgId  String
  statementDate        DateTime
  statementMerchant    String
  statementAmount      Float
  matchedTransactionId String?
  status               String
  mismatchDetails      String?
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MerchantRule {
  id           String   @id @default(cuid())
  userId       String
  merchantName String
  category     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
}

model StatementPassword {
  id                String   @id @default(cuid())
  userId            String
  senderDomain      String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderDomain])
}

model ParseLog {
  id               String    @id @default(cuid())
  userId           String
  syncJobId        String
  gmailMsgId       String
  senderDomain     String
  emailDate        DateTime?
  bodyLengthRaw    Int
  bodyLengthSent   Int
  wasTruncated     Boolean   @default(false)
  batchSize        Int       @default(1)
  outcome          String
  geminiConfidence Float?
  parsedMerchant   String?
  parsedAmount     Float?
  transactionId    String?
  errorDetail      String?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncJobId])
  @@index([userId, gmailMsgId])
  @@index([createdAt])
}

model GeminiUsageLog {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD (UTC) — one row per calendar day
  callCount Int      @default(0)

  @@unique([date])
}
