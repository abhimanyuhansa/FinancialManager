generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String              @id @default(cuid())
  email         String              @unique
  name          String?
  image         String?
  syncFromDate  DateTime?
  gmailSyncedAt DateTime?
  lastMessageId String?
  createdAt     DateTime            @default(now())
  emailVerified DateTime?
  accounts      Account[]
  assets        Asset[]
  categories    Category[]
  reconLogs     ReconciliationLog[]
  sessions      Session[]
  syncJobs           SyncJob[]
  transactions       Transaction[]
  merchantRules      MerchantRule[]
  statementPasswords StatementPassword[]
  parseLogs          ParseLog[]
  vpaMerchantMaps    VpaMerchantMap[]
  subCategories      SubCategory[]
  parseTemplates     ParseTemplate[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  gmailMsgId  String?
  fingerprint String?
  date        DateTime
  merchant    String
  amount      Float
  type        String
  currency    String   @default("INR")
  category    String
  tag         String?
  source      String   @default("gmail")
  sourceRank  Int      @default(3)
  reviewed    Boolean  @default(false)
  needsReview Boolean  @default(false)
  subCategory String?
  lineItems   Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailMsgId])
  @@unique([userId, fingerprint])
}

model Asset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  value     Float
  currency  String   @default("INR")
  asOf      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id            String        @id @default(cuid())
  userId        String
  name          String
  slug          String        @unique
  icon          String        @default("")
  isDefault     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subCategories SubCategory[]
}

model SubCategory {
  id         String   @id @default(cuid())
  userId     String
  name       String
  slug       String   @unique
  icon       String   @default("")
  isDefault  Boolean  @default(false)
  parentSlug String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     Category @relation(fields: [parentSlug], references: [slug], onDelete: Cascade)
}

model EmailFilter {
  id         String   @id @default(cuid())
  type       String
  value      String
  sourceRank Int      @default(3)
  isActive   Boolean  @default(true)
  addedAt    DateTime @default(now())
  note       String?

  @@unique([type, value])
}

model SyncJob {
  id                    String           @id @default(cuid())
  userId                String
  status                String           @default("running")
  totalEmails           Int              @default(0)
  processedEmails       Int              @default(0)
  newTransactions       Int              @default(0)
  skippedEmails         Int              @default(0)
  encryptedBlockedCount Int              @default(0)
  isRetrigger           Boolean          @default(false)
  startedAt             DateTime         @default(now())
  completedAt           DateTime?
  scanPageToken         String?
  gmailQuery            String?
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages              SyncJobMessage[]
}

model SyncJobMessage {
  id         String  @id @default(cuid())
  syncJobId  String
  gmailMsgId String
  processed  Boolean @default(false)
  syncJob    SyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@unique([syncJobId, gmailMsgId])
  @@index([syncJobId, processed])
}

model ReconciliationLog {
  id                   String    @id @default(cuid())
  userId               String
  statementGmailMsgId  String
  statementDate        DateTime
  statementMerchant    String
  statementAmount      Float
  matchedTransactionId String?
  status               String
  mismatchDetails      String?
  resolvedAt           DateTime?
  createdAt            DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MerchantRule {
  id           String   @id @default(cuid())
  userId       String
  merchantName String
  category     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
}

model StatementPassword {
  id                String   @id @default(cuid())
  userId            String
  senderDomain      String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderDomain])
}

model ParseLog {
  id               String    @id @default(cuid())
  userId           String
  syncJobId        String
  gmailMsgId       String
  senderDomain     String
  emailDate        DateTime?
  bodyLengthRaw    Int
  bodyLengthSent   Int
  wasTruncated     Boolean   @default(false)
  batchSize        Int       @default(1)
  outcome          String
  geminiConfidence Float?
  parsedMerchant   String?
  parsedAmount     Float?
  transactionId    String?
  errorDetail      String?
  resolvedBy       String?   // "static" | "template" | "gemini" | "exact_cache"
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncJobId])
  @@index([userId, gmailMsgId])
  @@index([createdAt])
}

model GeminiUsageLog {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD (UTC) — one row per calendar day
  callCount Int      @default(0)

  @@unique([date])
}

model GmailQueryKeyword {
  id        String   @id @default(cuid())
  type      String   // "from" | "subject"
  value     String
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(true)
  addedAt   DateTime @default(now())

  @@unique([type, value])
}

model ExclusionRule {
  id       String   @id @default(cuid())
  type     String   // "sender_domain" | "sender_email"
  value    String
  isActive Boolean  @default(true)
  note     String?
  addedAt  DateTime @default(now())

  @@unique([type, value])
}

model MerchantMaster {
  id           String   @id @default(cuid())
  merchantName String   @unique  // normalised lowercase
  category     String
  subCategory  String?
  confidence   Float    @default(0)
  source       String   // "llm" | "user"
  updatedAt    DateTime @updatedAt
}

model SubCategoryMaster {
  id          String  @id @default(cuid())
  category    String
  subCategory String
  isDefault   Boolean @default(false)
  addedBy     String  @default("system") // "system" | "user" | "llm"

  @@unique([category, subCategory])
}

model VpaMerchantMap {
  id              String   @id @default(cuid())
  userId          String
  vpa             String
  merchantName    String
  category        String   @default("other")
  subCategory     String?
  confirmedByUser Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, vpa])
  @@index([userId])
}

model ParseTemplate {
  id                   String    @id @default(cuid())
  userId               String
  senderDomain         String
  templateHash         String
  parserVersion        String
  taxonomyVersion      String    @default("")
  status               String    // SHADOW | ACTIVE | DEGRADED | DISABLED
  subjectTemplate      String
  bodyTemplate         String
  extractors           Json
  hitCount             Int       @default(0)
  failCount            Int       @default(0)
  consecutiveSuccesses Int       @default(0)
  consecutiveFailures  Int       @default(0)
  promotedAt           DateTime?
  lastUsedAt           DateTime?
  lastFailedAt         DateTime?
  disabledReason       String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderDomain, templateHash, parserVersion])
  @@index([userId, senderDomain, status])
}

model LlmCallLog {
  id               String   @id @default(cuid())
  syncJobId        String?
  userId           String?
  batchKey         String?
  provider         String
  model            String
  candidateCount   Int
  attemptNumber    Int
  wasFallback      Boolean  @default(false)
  fallbackReason   String?
  outcome          String
  errorDetail      String?
  latencyMs        Int
  inputTokens      Int
  outputTokens     Int
  estimatedCostUsd Decimal
  createdAt        DateTime @default(now())

  @@index([provider, createdAt])
  @@index([syncJobId])
  @@index([batchKey])
}

model LlmQuotaWindow {
  id         String   @id @default(cuid())
  provider   String
  windowType String
  windowKey  String
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([provider, windowType, windowKey])
  @@index([provider, windowType, windowKey])
}

model LlmCircuitBreaker {
  provider            String    @id
  state               String    @default("CLOSED")
  consecutiveFailures Int       @default(0)
  lastFailureAt       DateTime?
  openedAt            DateTime?
  updatedAt           DateTime  @updatedAt
}

model LlmBatchIdempotency {
  id        String   @id @default(cuid())
  batchKey  String   @unique
  status    String
  result    Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

model SyncJobLock {
  jobId      String   @id
  ownerToken String
  lockedAt   DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}
